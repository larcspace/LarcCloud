# Configuration LARC Migration

# Old Production (Supabase Prod actuelle)
OLD_PROD_URL=https://your-old-prod.supabase.co
OLD_PROD_ANON_KEY=your-old-anon-key
OLD_PROD_SERVICE_ROLE_KEY=your-old-service-role-key

# Non-Production (Nouvelle base Supabase hors prod)
NON_PROD_URL=https://your-non-prod.supabase.co
NON_PROD_ANON_KEY=your-non-prod-anon-key
NON_PROD_SERVICE_ROLE_KEY=your-non-prod-service-role-key

# Cloud (Miroir Supabase Cloud)
CLOUD_URL=https://your-cloud.supabase.co
CLOUD_ANON_KEY=your-cloud-anon-key
CLOUD_SERVICE_ROLE_KEY=your-cloud-service-role-key

# Daemon Configuration
SYNC_INTERVAL_SECONDS=60
LOG_LEVEL=INFO
BATCH_SIZE=100
